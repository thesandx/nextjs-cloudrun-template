###############################################################################
# Environment variable reference.
#
# Copy to `.env.local` for local development:
#     cp .env.example .env.local
#
# `.env.local` is gitignored. This file is the tracked contract: every variable
# the application reads MUST be documented here and declared in `lib/env.ts`.
# Nothing in this file may contain a real secret.
#
# Where each variable comes from in production:
#   - PORT / HOSTNAME .................. injected by Cloud Run
#   - NEXT_PUBLIC_* .................... baked in at build time by the Docker
#                                        build args in .github/workflows/deploy.yml
#   - everything else .................. set as Cloud Run env vars or, for
#                                        secrets, mounted from Secret Manager
###############################################################################

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Node runtime mode. Set automatically by `next dev` / `next build` / Docker.
# Do not set this by hand in .env.local.
# Values: development | production | test
NODE_ENV=development

# TCP port the server binds to.
# Cloud Run injects this (8080 by default) and the container MUST honour it —
# a hardcoded port is the #1 cause of "container failed to start" deploys.
# Default: 3000 locally, 8080 in the container.
PORT=3000

# Network interface to bind. Must be 0.0.0.0 inside a container, otherwise the
# process is unreachable from outside it. Set to 0.0.0.0 in the Dockerfile.
# Default: 0.0.0.0
HOSTNAME=0.0.0.0

# Minimum severity that gets logged. Anything below is dropped.
# Values: debug | info | warn | error
# Default: info. Use `debug` locally, keep `info` in production.
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Application — public (INLINED INTO THE CLIENT BUNDLE)
#
# WARNING: every NEXT_PUBLIC_* value is embedded in the JavaScript served to
# browsers and is therefore public. Never put a credential behind this prefix.
# These are read at BUILD time, so changing them requires a rebuild, not just a
# Cloud Run env var update.
# -----------------------------------------------------------------------------

# Canonical public origin. Used for metadataBase, canonical URLs, OG images.
# Required in production. In CI this is set to the Cloud Run service URL.
# Example: https://my-app-abc123-as.a.run.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Display name shown in page titles and structured logs.
NEXT_PUBLIC_APP_NAME=Next.js on Cloud Run

# Build identifier. CI sets this to the commit SHA so /api/health reports
# exactly which revision is serving traffic.
# Default: dev
NEXT_PUBLIC_APP_VERSION=dev

# -----------------------------------------------------------------------------
# Google Cloud
#
# Not required to run the app locally. Cloud Run populates the identity it needs
# via the attached service account and the metadata server — never ship a key.
# -----------------------------------------------------------------------------

# GCP project that owns Artifact Registry and the Cloud Run service.
# Also configured as the GCP_PROJECT_ID GitHub Actions variable.
GCP_PROJECT_ID=

# Deployment region, e.g. asia-southeast1, europe-west1, us-central1.
# Must match the Artifact Registry repository's region to avoid cross-region
# image pulls (slower cold starts and egress cost).
GCP_REGION=asia-southeast1

# -----------------------------------------------------------------------------
# Secrets — examples only, uncomment and adapt per project
#
# Never store real secrets in any .env file that is committed. In production,
# create them in Secret Manager and reference them from Cloud Run:
#
#   gcloud secrets create DATABASE_URL --replication-policy=automatic
#   printf '%s' "$VALUE" | gcloud secrets versions add DATABASE_URL --data-file=-
#   gcloud run services update SERVICE --set-secrets=DATABASE_URL=DATABASE_URL:latest
#
# See cloud/environment-variables.md for the full procedure.
# -----------------------------------------------------------------------------

# DATABASE_URL=postgresql://user:password@host:5432/dbname
# API_KEY=
# NEXTAUTH_SECRET=
