# Fail installs when the lockfile disagrees with package.json in CI.
# Locally, `pnpm install` still updates the lockfile as normal.
strict-peer-dependencies=false

# Hoist nothing implicitly. A package must be declared in package.json to be
# importable — this catches phantom dependencies that would break in Docker,
# where the module tree is traced rather than copied wholesale.
shamefully-hoist=false

# Reproducible installs: prefer the lockfile's resolution over re-resolving.
prefer-frozen-lockfile=true
